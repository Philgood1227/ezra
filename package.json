{
  "name": "ezra",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "storybook": "set STORYBOOK=true&& set STORYBOOK_DISABLE_TELEMETRY=1&& storybook dev -p 6006",
    "storybook:build": "set STORYBOOK=true&& set STORYBOOK_DISABLE_TELEMETRY=1&& set CI=1&& storybook build",
    "db:types": "supabase gen types typescript --local > src/types/database.ts"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@supabase/ssr": "^0.8.0",
